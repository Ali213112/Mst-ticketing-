NODE_ENV=development
PORT=5000
LOG_LEVEL=debug

# Web3Auth
WEB3AUTH_CLIENT_ID=your_web3auth_client_id
WEB3AUTH_JWKS_URL=https://api-auth.web3auth.io/jwks
WEB3AUTH_ISSUER=https://api-auth.web3auth.io

# SARAL SSO (legacy — optional)
SARAL_APP_ID=your_app_id
SARAL_APP_SECRET=your_app_secret
SARAL_ENVIRONMENT=testnet

# Database (Docker)
DATABASE_URL=postgresql://ticketchain_user:dev_password@localhost:15432/ticketchain
DATABASE_POOL_SIZE=10

# Redis (Docker)
REDIS_URL=redis://localhost:6379

# JWT (RS256) — generate with openssl in apps/api/certs/
JWT_PRIVATE_KEY_PATH=./certs/private.pem
JWT_PUBLIC_KEY_PATH=./certs/public.pem
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# MST Blockchain — testnet via @mstblockchain/mst-sdk
MST_RPC_URL=https://testnetrpc.mstblockchain.com
MST_RPC_FALLBACK_URL=
MST_CHAIN_ID=4545
MST_NETWORK=testnet
MST_DEPLOYER_PRIVATE_KEY=

# Contract addresses (filled after deploy)
ORG_REGISTRY_ADDRESS=

# IPFS / Pinata
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_GATEWAY=https://gateway.pinata.cloud

# ChainPay (crypto checkout — https://chainpay.biz/integration-docs)
CHAINPAY_API_KEY=
CHAINPAY_API_URL=https://sandbox-api.chainpay.biz
CHAINPAY_DEFAULT_CURRENCY=INR
PAYMENTS_WEBHOOK_SECRET=
ALLOW_DIRECT_MINT=true

# AWS S3 (temp upload staging)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-south-1

# Email
SENDGRID_API_KEY=
EMAIL_FROM=noreply@ticketchain.com

# App URLs
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=your_web3auth_client_id
NEXT_PUBLIC_MST_CHAIN_ID=4545
NEXT_PUBLIC_MST_RPC_URL=https://testnetrpc.mstblockchain.com
NEXT_PUBLIC_ALLOW_DIRECT_MINT=true
